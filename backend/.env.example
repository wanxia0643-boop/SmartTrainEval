# ========= 应用 =========
APP_NAME=SmartTrainEval
APP_ENV=dev
DEBUG=true
API_PREFIX=/api/v1

# ========= 数据库 =========
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=beyond
# 数据库密码（密文）：用 python -m scripts.encrypt_secret <明文> 生成 ENC(...) 与密钥
# 也兼容直接填明文（不推荐）
DB_PASSWORD=ENC(请用 scripts.encrypt_secret 生成后替换)
DB_NAME=smart_train_eval
DB_ECHO=false

# 配置解密密钥（Fernet）：仅放本地 .env / 环境变量，切勿提交到仓库
CONFIG_ENC_KEY=

# ========= JWT =========
# 生产环境请改为随机长字符串：python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-change-this-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720

# ========= 大模型 =========
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TEMPERATURE=0.2

# ========= 魔珐星云数字人 =========
# 真实 App ID / App Secret 只写入本地 backend/.env，切勿提交到仓库。
XINGYUN_APP_ID=
XINGYUN_APP_SECRET=
XINGYUN_GATEWAY_SERVER=https://nebula-agent.xingyun3d.com/user/v1/ttsa/session
XINGYUN_SDK_URL=https://media.xingyun3d.com/xingyun3d/general/litesdk/xmovAvatar@latest.js
